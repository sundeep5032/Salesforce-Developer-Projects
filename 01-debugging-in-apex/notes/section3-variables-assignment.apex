//Variables declaration without initialization (default value = null)
Integer num1;
System.debug('num1 before assignment = ' + num1);

//Assigned value later
num1=10;
System.debug('num1 after assigner =' + num1);

//Declaration with initialization (recommended)
Integer num2=20;
System.debug('num2 is =' + num2);

/*
    NOTE: In Salesforce all the above will consider as "Variable Assignments"
*/
